# OpenClaw
OPENCLAW_API_KEY=your_key
OPENCLAW_TEAM_ID=defi_ghost_team

# Ethoswarm (Animoca Minds)
ETHOSWARM_API_KEY=your_key
ETHOSWARM_MEMORY_STORE_ID=your_store_id

# LLM: openai | venice (see backend/AI_MODELS.md)
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# Venice.ai (optional)
VENICE_API_KEY=
VENICE_API_BASE=https://api.venice.ai/v1
VENICE_MODEL=venice-v1

# RPCs
ETH_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# Redis (optional for local dev)
REDIS_URL=redis://localhost:6379
